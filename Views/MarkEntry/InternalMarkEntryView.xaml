<UserControl x:Class="ACGCET_Faculty.Views.MarkEntry.InternalMarkEntryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:ACGCET_Faculty.ViewModels.MarkEntry"
             d:DataContext="{d:DesignInstance Type=vm:InternalMarkEntryViewModel}"
             mc:Ignorable="d"
             d:DesignHeight="700"
        d:DesignWidth="1000"
             Background="{DynamicResource MaterialDesign.Brush.Background}">

    <Grid Margin="20 16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel Grid.Row="0"
                Orientation="Horizontal"
                Margin="0 0 0 14">
            <md:PackIcon Kind="NoteEdit"
                    Width="26"
                    Height="26"
                         Foreground="#6A1B9A"
                    VerticalAlignment="Center"
                         Margin="0 0 10 0"/>
            <TextBlock Text="Internal Mark Entry"
                    FontSize="20"
                       FontWeight="Bold"
                    Foreground="#4A148C"
                       VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Lock Warning -->
        <Border Grid.Row="1"
                Padding="16 12"
                Margin="0 0 0 14"
                BorderThickness="1"
                Visibility="{Binding IsModuleLocked,
                             Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border.Background>
                <SolidColorBrush Color="#FFEBEE"/>
            </Border.Background>
            <Border.BorderBrush>
                <SolidColorBrush Color="#FFCDD2"/>
            </Border.BorderBrush>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal"
                        Grid.Column="0">
                    <md:PackIcon Kind="Lock"
                            Foreground="#C62828"
                                 Width="22"
                            Height="22"
                            VerticalAlignment="Center"
                                 Margin="0 0 12 0"/>
                    <TextBlock Text="{Binding LockMessage}"
                            Foreground="#B71C1C"
                               FontSize="13"
                            FontWeight="SemiBold"
                               TextWrapping="Wrap"
                            VerticalAlignment="Center"/>
                </StackPanel>
                <Button Grid.Column="1"
                        Content="REQUEST OVERRIDE"
                        Command="{Binding RequestLockOverrideCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Foreground="#C62828"
                        BorderBrush="#FFCDD2"
                        VerticalAlignment="Center"
                        Margin="12 0 0 0"/>
            </Grid>
        </Border>

        <!-- Lock Override Request Panel -->
        <md:Card Grid.Row="1"
                Margin="0 50 0 12"
                Padding="16 14"
                Background="#FFF3E0"
                 Visibility="{Binding IsLockOverridePanelVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel>
                <TextBlock Text="Request Lock Override from COE"
                        FontWeight="Bold"
                        FontSize="14"
                           Foreground="#E65100"
                        Margin="0 0 0 10"/>
                <TextBox Text="{Binding LockOverrideReason, UpdateSourceTrigger=PropertyChanged}"
                         md:HintAssist.Hint="Reason for requesting override (required)"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Background="White"
                        MinLines="2"
                        TextWrapping="Wrap"
                         Margin="0 0 0 10"/>
                <StackPanel Orientation="Horizontal">
                    <Button Content="SUBMIT REQUEST"
                            Command="{Binding SubmitLockOverrideCommand}"
                            Style="{StaticResource MaterialDesignFlatAccentBgButton}"
                            Background="#E65100"
                            Foreground="White"
                            BorderBrush="#E65100"
                            Margin="0 0 10 0"/>
                    <Button Content="CANCEL"
                            Command="{Binding CancelLockOverrideCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Foreground="#666"
                            BorderBrush="#CCC"/>
                </StackPanel>
            </StackPanel>
        </md:Card>

        <!-- Filter Card -->
        <md:Card Grid.Row="2"
                Margin="0 0 0 12"
                 Padding="16 14"
                 Background="White">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Row 1: Course / Batch / Section -->
                <Grid Grid.Row="0"
                        Margin="0 0 0 12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <ComboBox Grid.Column="0"
                            Margin="0 0 10 0"
                              ItemsSource="{Binding Courses}"
                              SelectedItem="{Binding SelectedCourse}"
                              md:HintAssist.Hint="Course / Department"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                              DisplayMemberPath="CourseName"/>
                    <ComboBox Grid.Column="1"
                            Margin="0 0 10 0"
                              ItemsSource="{Binding Batches}"
                              SelectedItem="{Binding SelectedBatch}"
                              md:HintAssist.Hint="Batch"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                              DisplayMemberPath="BatchName"/>
                    <ComboBox Grid.Column="2"
                              ItemsSource="{Binding Sections}"
                              SelectedItem="{Binding SelectedSection}"
                              md:HintAssist.Hint="Section"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                              DisplayMemberPath="SectionName"/>
                </Grid>

                <!-- Row 2: Semester / Paper / Load -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ComboBox Grid.Column="0"
                            Margin="0 0 10 0"
                              ItemsSource="{Binding Semesters}"
                              SelectedItem="{Binding SelectedSemester}"
                              md:HintAssist.Hint="Sem"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}"/>
                    <ComboBox Grid.Column="1"
                            Margin="0 0 10 0"
                              ItemsSource="{Binding Papers}"
                              SelectedItem="{Binding SelectedPaper}"
                              md:HintAssist.Hint="Paper / Subject"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock>
                                    <Run Text="{Binding PaperCode, Mode=OneWay}"/>
                                    <Run Text=" — "/>
                                    <Run Text="{Binding PaperName, Mode=OneWay}"/>
                                </TextBlock>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <Button Grid.Column="2"
                            Command="{Binding LoadStudentsCommand}"
                            IsEnabled="{Binding IsNotLoading}"
                            Style="{StaticResource MaterialDesignFlatAccentBgButton}"
                            Background="#FF673AB7"
                            Foreground="White"
                            BorderBrush="Transparent"
                            Height="40">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="AccountSearch"
                                    VerticalAlignment="Center"
                                         Margin="0 0 6 0"/>
                            <TextBlock Text="Load Students"
                                    VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Grid>
        </md:Card>

        <!-- Status message -->
        <Border Grid.Row="3"
                Padding="10 7"
                Margin="0 0 0 10"
                BorderThickness="1"
                Visibility="{Binding StatusMessage,
                             Converter={StaticResource StringToVisibilityConverter}}">
            <Border.Background>
                <SolidColorBrush Color="{Binding StatusColor}"
                        Opacity="0.08"/>
            </Border.Background>
            <Border.BorderBrush>
                <SolidColorBrush Color="{Binding StatusColor}"
                        Opacity="0.3"/>
            </Border.BorderBrush>
            <StackPanel Orientation="Horizontal">
                <md:PackIcon Kind="InformationOutline"
                        Width="16"
                        Height="16"
                             Foreground="{Binding StatusColor}"
                             VerticalAlignment="Center"
                        Margin="0 0 8 0"/>
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{Binding StatusColor}"
                           FontSize="12"
                        FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Student DataGrid -->
        <md:Card Grid.Row="4"
                 ClipToBounds="True"
                 Background="White">
            <Grid>
                <!-- Loading overlay -->
                <Border Panel.ZIndex="10"
                        Background="#F5F5F5"
                        Visibility="{Binding IsLoading,
                                     Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                        <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                                     IsIndeterminate="True"
                                Value="0"
                                     Width="44"
                                Height="44"/>
                        <TextBlock Text="Loading students..."
                                Foreground="#7B1FA2"
                                   FontSize="13"
                                HorizontalAlignment="Center"
                                   Margin="0 12 0 0"/>
                    </StackPanel>
                </Border>

                <!-- Empty state -->
                <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                            Margin="0 40">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility"
                                    Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasStudents}"
                                        Value="False">
                                    <Setter Property="Visibility"
                                            Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <md:PackIcon Kind="AccountGroupOutline"
                            Width="64"
                            Height="64"
                                 Foreground="#BDBDBD"
                            HorizontalAlignment="Center"/>
                    <TextBlock Text="Select Course, Batch, Section, Semester and Paper"
                               Foreground="#9E9E9E"
                            FontSize="14"
                               HorizontalAlignment="Center"
                            Margin="0 12 0 4"/>
                    <TextBlock Text="then click  Load Students  to begin entering marks"
                               Foreground="#BDBDBD"
                            FontSize="12"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Marks DataGrid -->
                <DataGrid ItemsSource="{Binding Students}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                        CanUserDeleteRows="False"
                          CanUserReorderColumns="False"
                          HeadersVisibility="Column"
                        SelectionMode="Single"
                          Style="{StaticResource MaterialDesignDataGrid}"
                          Visibility="{Binding HasStudents,
                                       Converter={StaticResource BooleanToVisibilityConverter}}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="#"
                                Width="40"
                                IsReadOnly="True"
                                            Binding="{Binding RollNumber}"/>
                        <DataGridTextColumn Header="Reg No"
                                Width="110"
                                IsReadOnly="True"
                                            Binding="{Binding RegistrationNumber}"/>
                        <DataGridTextColumn Header="Student Name"
                                Width="*"
                                IsReadOnly="True"
                                            Binding="{Binding FullName}"/>
                        <DataGridTextColumn Header="CIA 1"
                                Width="72"
                                            Binding="{Binding MarkCIA1,   UpdateSourceTrigger=PropertyChanged}"/>
                        <DataGridTextColumn Header="CIA 2"
                                Width="72"
                                            Binding="{Binding MarkCIA2,   UpdateSourceTrigger=PropertyChanged}"/>
                        <DataGridTextColumn Header="CIA 3"
                                Width="72"
                                            Binding="{Binding MarkCIA3,   UpdateSourceTrigger=PropertyChanged}"/>
                        <DataGridTextColumn Header="Model"
                                Width="72"
                                            Binding="{Binding MarkModel, UpdateSourceTrigger=PropertyChanged}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </md:Card>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="5"
                Orientation="Horizontal"
                    HorizontalAlignment="Right"
                Margin="0 14 0 0">
            <Button Content="Clear"
                    Command="{Binding ClearFormCommand}"
                    Background="White"
                    BorderBrush="#FF673AB7"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Margin="0 0 12 0"
                    Padding="18 8"/>

            <Button Command="{Binding SaveMarksCommand}"
                    IsEnabled="{Binding CanSave}"
                    Style="{StaticResource MaterialDesignFlatAccentBgButton}"
                    Background="#FF673AB7"
                    Foreground="White"
                    BorderBrush="#FF673AB7"
                    Padding="24 10">
                <StackPanel Orientation="Horizontal">
                    <md:PackIcon Kind="ContentSave"
                            VerticalAlignment="Center"
                                 Margin="0 0 8 0"/>
                    <TextBlock Text="Save Marks"
                            VerticalAlignment="Center"
                               FontWeight="SemiBold"/>
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
