<UserControl x:Class="ACGCET_Faculty.Views.StudentMaster.StudentMasterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:ACGCET_Faculty.ViewModels.StudentMaster"
             d:DataContext="{d:DesignInstance Type=vm:StudentMasterViewModel}"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1000"
             Background="{DynamicResource MaterialDesign.Brush.Background}">

    <Grid Margin="20 16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0 0 0 14">
            <md:PackIcon Kind="AccountMultiple" Width="26" Height="26"
                         Foreground="#6A1B9A" VerticalAlignment="Center" Margin="0 0 10 0"/>
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Student Master" FontSize="20" FontWeight="Bold"
                           Foreground="#4A148C"/>
                <TextBlock Text="View all enrolled students"
                           FontSize="11" Foreground="#9E9E9E"/>
            </StackPanel>
        </StackPanel>

        <!-- Lock / Open Banner -->
        <Border Grid.Row="1"  Padding="14 10" Margin="0 0 0 12" 
                BorderThickness="1">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="#E8F5E9"/>
                    <Setter Property="BorderBrush" Value="#A5D6A7"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsDataEntryLocked}" Value="True">
                            <Setter Property="Background" Value="#FFF3E0"/>
                            <Setter Property="BorderBrush" Value="#FFCC80"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel Orientation="Horizontal">
                <md:PackIcon Width="18" Height="18" VerticalAlignment="Center" Margin="0 0 10 0">
                    <md:PackIcon.Style>
                        <Style TargetType="md:PackIcon">
                            <Setter Property="Kind" Value="LockOpen"/>
                            <Setter Property="Foreground" Value="#2E7D32"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsDataEntryLocked}" Value="True">
                                    <Setter Property="Kind" Value="Lock"/>
                                    <Setter Property="Foreground" Value="#E65100"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </md:PackIcon.Style>
                </md:PackIcon>
                <TextBlock FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="Student Master is open. Records are read-only for faculty."/>
                            <Setter Property="Foreground" Value="#2E7D32"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsDataEntryLocked}" Value="True">
                                    <Setter Property="Foreground" Value="#E65100"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBlock Text="{Binding LockMessage}" FontSize="12" FontWeight="SemiBold"
                           Foreground="#E65100" VerticalAlignment="Center" Margin="6 0 0 0"
                           Visibility="{Binding IsDataEntryLocked, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            </StackPanel>
        </Border>

        <!-- Filter Card -->
        <md:Card Grid.Row="2" Margin="0 0 0 12" 
                  Padding="16 14" Background="White">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ComboBox Grid.Column="0" Margin="0 0 10 0"
                          ItemsSource="{Binding Courses}"
                          SelectedItem="{Binding SelectedCourse}"
                          md:HintAssist.Hint="Course / Dept"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          Background="White"
                          DisplayMemberPath="CourseName"/>
                <ComboBox Grid.Column="1" Margin="0 0 10 0"
                          ItemsSource="{Binding Batches}"
                          SelectedItem="{Binding SelectedBatch}"
                          md:HintAssist.Hint="Batch"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          Background="White"
                          DisplayMemberPath="BatchName"/>
                <ComboBox Grid.Column="2" Margin="0 0 10 0"
                          ItemsSource="{Binding Sections}"
                          SelectedItem="{Binding SelectedSection}"
                          md:HintAssist.Hint="Section (optional)"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          Background="White"
                          DisplayMemberPath="SectionName"/>
                <Button Grid.Column="3"
                        Command="{Binding LoadStudentsCommand}"
                        Style="{StaticResource MaterialDesignFlatAccentBgButton}"
                        Background="#FF673AB7"
                        Foreground="White"
                        BorderBrush="#FF673AB7"
                        Height="40">
                    <StackPanel Orientation="Horizontal">
                        <md:PackIcon Kind="AccountSearch" VerticalAlignment="Center" Margin="0 0 6 0"/>
                        <TextBlock Text="Load Students" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </md:Card>

        <!-- Student Grid -->
        <md:Card Grid.Row="3" 
                  ClipToBounds="True" Background="White">
            <Grid>
                <!-- Loading overlay -->
                <Border Panel.ZIndex="10"  Background="#F5F5F5"
                        Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                                     IsIndeterminate="True" Value="0" Width="44" Height="44"/>
                        <TextBlock Text="Loading students..." Foreground="#7B1FA2"
                                   FontSize="13" HorizontalAlignment="Center" Margin="0 12 0 0"/>
                    </StackPanel>
                </Border>

                <!-- Empty state -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0 40">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasStudents}" Value="False">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <md:PackIcon Kind="AccountGroupOutline" Width="64" Height="64"
                                 Foreground="#BDBDBD" HorizontalAlignment="Center"/>
                    <TextBlock Text="Select a Course and click Load Students"
                               Foreground="#9E9E9E" FontSize="14"
                               HorizontalAlignment="Center" Margin="0 12 0 4"/>
                </StackPanel>

                <DataGrid ItemsSource="{Binding Students}"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          CanUserAddRows="False" CanUserReorderColumns="False"
                          HeadersVisibility="Column"
                          Style="{StaticResource MaterialDesignDataGrid}"
                          Visibility="{Binding HasStudents, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Reg No"   Width="120"
                            Binding="{Binding RegistrationNumber}"/>
                        <DataGridTextColumn Header="Roll No"  Width="80"
                            Binding="{Binding RollNumber}"/>
                        <DataGridTextColumn Header="Name"     Width="*"
                            Binding="{Binding FullName}"/>
                        <DataGridTextColumn Header="Gender"   Width="70"
                            Binding="{Binding Gender}"/>
                        <DataGridTextColumn Header="DOB"      Width="100"
                            Binding="{Binding DateOfBirth, StringFormat='{}{0:dd-MM-yyyy}'}"/>
                        <DataGridTextColumn Header="Course"   Width="200"
                            Binding="{Binding Course.CourseName}"/>
                        <DataGridTextColumn Header="Batch"    Width="90"
                            Binding="{Binding Batch.BatchName}"/>
                        <DataGridTextColumn Header="Section"  Width="70"
                            Binding="{Binding Section.SectionName}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </md:Card>
    </Grid>
</UserControl>
