<UserControl x:Class="ACGCET_Faculty.Views.Dashboard.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:ACGCET_Faculty.ViewModels.Dashboard"
             xmlns:converters="clr-namespace:ACGCET_Faculty.Converters"
             d:DataContext="{d:DesignInstance Type=vm:LoginViewModel}"
             mc:Ignorable="d"
             d:DesignHeight="700"
             d:DesignWidth="1100">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BTV"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBTV"/>
        <Style x:Key="LoginTextBox"
               TargetType="TextBox"
               BasedOn="{StaticResource MaterialDesignOutlinedTextBox}">
            <Setter Property="Margin"
                    Value="0 0 0 16"/>
            <Setter Property="Height"
                    Value="52"/>
            <Setter Property="FontSize"
                    Value="14"/>
        </Style>
        <Style x:Key="LoginPasswordBox"
               TargetType="PasswordBox"
               BasedOn="{StaticResource MaterialDesignOutlinedPasswordBox}">
            <Setter Property="Height"
                    Value="52"/>
            <Setter Property="FontSize"
                    Value="14"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="420"
                              MinWidth="360"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══ LEFT PANEL — Login Form ══════════════════════════════════ -->
        <Grid Grid.Column="0"
              Background="White">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="44 48 44 48">

                    <!-- Brand -->
                    <StackPanel Orientation="Horizontal"
                                Margin="0 0 0 36">
                        <Image Source="pack://application:,,,/Resources/Images/acgcet_logo.png"
                               Width="48"
                               Height="48"
                               VerticalAlignment="Center"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                        <StackPanel Margin="12 0 0 0"
                                    VerticalAlignment="Center">
                            <TextBlock Text="ACGCET"
                                       FontSize="17"
                                       FontWeight="Bold"
                                       Foreground="#7C3AED"
                                       FontFamily="Segoe UI Variable Display, Segoe UI"/>
                            <TextBlock Text="Faculty Portal"
                                       FontSize="12"
                                       Foreground="#71717A"
                                       FontFamily="Segoe UI Variable Display, Segoe UI"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Heading -->
                    <TextBlock Text="Welcome Back"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="#09090B"
                               Margin="0 0 0 6"
                               FontFamily="Segoe UI Variable Display, Segoe UI"/>
                    <TextBlock Text="Sign in to enter marks and manage student records."
                               FontSize="13"
                               Foreground="#71717A"
                               TextWrapping="Wrap"
                               Margin="0 0 0 32"
                               FontFamily="Segoe UI Variable Display, Segoe UI"/>

                    <!-- Username -->
                    <TextBlock Text="Username"
                               FontSize="12"
                               FontWeight="Medium"
                               Foreground="#49454F"
                               Margin="0 0 0 4"/>
                    <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource LoginTextBox}"
                             IsEnabled="{Binding IsNotLoading}"
                             md:TextFieldAssist.HasClearButton="True"/>

                    <!-- Password -->
                    <TextBlock Text="Password"
                               FontSize="12"
                               FontWeight="Medium"
                               Foreground="#49454F"
                               Margin="0 0 0 4"/>
                    <Grid Margin="0 0 0 24">
                        <!-- Hidden mode: PasswordBox -->
                        <PasswordBox x:Name="pbPassword"
                                     Style="{StaticResource LoginPasswordBox}"
                                     Margin="0"
                                     IsEnabled="{Binding IsNotLoading}"
                                     PasswordChanged="PasswordBox_PasswordChanged"
                                     Visibility="{Binding IsPasswordVisible, Converter={StaticResource InverseBTV}}"/>
                        <!-- Visible mode: TextBox -->
                        <TextBox Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource LoginTextBox}"
                                 Margin="0"
                                 IsEnabled="{Binding IsNotLoading}"
                                 Visibility="{Binding IsPasswordVisible, Converter={StaticResource BTV}}"/>
                        <!-- Eye toggle -->
                        <Button HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Margin="0 0 6 0"
                                Width="34"
                                Height="34"
                                Style="{StaticResource MaterialDesignIconButton}"
                                Command="{Binding TogglePasswordVisibilityCommand}"
                                IsEnabled="{Binding IsNotLoading}"
                                Foreground="#9E9E9E">
                            <Grid>
                                <md:PackIcon Kind="Eye"
                                             Width="20"
                                             Height="20"
                                             Visibility="{Binding IsPasswordVisible, Converter={StaticResource BTV}}"/>
                                <md:PackIcon Kind="EyeOff"
                                             Width="20"
                                             Height="20"
                                             Visibility="{Binding IsPasswordVisible, Converter={StaticResource InverseBTV}}"/>
                            </Grid>
                        </Button>
                    </Grid>

                    <!-- Error Banner -->
                    <Border Padding="12 10"
                            Margin="0 0 0 12"
                            BorderThickness="1"
                            BorderBrush="#FECACA"
                            Background="#FEF2F2"
                            Visibility="{Binding IsErrorVisible, Converter={StaticResource BTV}}">
                        <DockPanel>
                            <md:PackIcon Kind="AlertCircleOutline"
                                         Foreground="#C62828"
                                         Width="18"
                                         Height="18"
                                         VerticalAlignment="Top"
                                         Margin="0 2 8 0"
                                         DockPanel.Dock="Left"/>
                            <TextBlock Text="{Binding ErrorMessage}"
                                       Foreground="#B71C1C"
                                       FontSize="13"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Center"/>
                        </DockPanel>
                    </Border>

                    <!-- Sign In Button -->
                    <Button Command="{Binding LoginCommand}"
                            IsEnabled="{Binding IsNotLoading}"
                            Visibility="{Binding IsNotLoading, Converter={StaticResource BTV}}"
                            Background="#7C3AED"
                            Foreground="White"
                            Height="48"
                            FontSize="15"
                            FontWeight="Bold"
                            md:ButtonAssist.CornerRadius="0"
                            md:ElevationAssist.Elevation="Dp0"
                            Margin="0 4 0 0">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="Login"
                                         Width="20"
                                         Height="20"
                                         VerticalAlignment="Center"
                                         Margin="0 0 8 0"/>
                            <TextBlock Text="SIGN IN"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Loading -->
                    <StackPanel HorizontalAlignment="Center"
                                Margin="0 20 0 0"
                                Visibility="{Binding IsLoading, Converter={StaticResource BTV}}">
                        <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                                     IsIndeterminate="True"
                                     Value="0"
                                     Width="36"
                                     Height="36"
                                     Foreground="#7C3AED"/>
                        <TextBlock Text="Signing in…"
                                   Foreground="#757575"
                                   FontSize="12"
                                   HorizontalAlignment="Center"
                                   Margin="0 8 0 0"/>
                    </StackPanel>

                    <!-- Footer -->
                    <TextBlock HorizontalAlignment="Center"
                               Margin="0 48 0 0"
                               FontSize="10"
                               Foreground="#BDBDBD"
                               TextAlignment="Center">
                        Alagappa Chettiar Government College of Engineering and Technology
                        <LineBreak/>Karaikudi — 630 003, Tamil Nadu
                    </TextBlock>
                </StackPanel>
            </ScrollViewer>
            <!-- Purple accent line on right edge -->
            <Rectangle Width="4"
                       HorizontalAlignment="Right"
                       Fill="#7C3AED"/>
        </Grid>

        <!-- ══ RIGHT PANEL — College Image ══════════════════════════════ -->
        <Grid Grid.Column="1"
              ClipToBounds="True">
            <Image Source="pack://application:,,,/Resources/Images/college_building.jpg"
                   Stretch="UniformToFill"
                   RenderOptions.BitmapScalingMode="HighQuality"/>
            <!-- Dark overlay -->
            <Rectangle Fill="#CC190030"/>
            <!-- College info at bottom -->
            <StackPanel VerticalAlignment="Bottom"
                        Margin="48 0 48 56">
                <TextBlock FontSize="30"
                           FontWeight="Bold"
                           Foreground="White"
                           TextWrapping="Wrap"
                           LineHeight="40">
                    Alagappa Chettiar Government&#10;College of Engineering and Technology
                </TextBlock>
                <TextBlock Text="Karaikudi — 630 003, Tamil Nadu"
                           FontSize="14"
                           Foreground="#CCFFFFFF"
                           Margin="0 10 0 0"/>
                <Rectangle Height="2"
                           Width="120"
                           HorizontalAlignment="Left"
                           Fill="#994A148C"
                           Margin="0 16 0 16"/>
                <TextBlock Text="Integrity  ·  Industry  ·  Enterprise"
                           FontSize="12"
                           Foreground="#AAFFFFFF"
                           FontStyle="Italic"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
