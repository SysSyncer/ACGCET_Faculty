<UserControl x:Class="ACGCET_Faculty.Views.Dashboard.FacultyDashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:ACGCET_Faculty.ViewModels.Dashboard"
             xmlns:meVm="clr-namespace:ACGCET_Faculty.ViewModels.MarkEntry"
             xmlns:meV="clr-namespace:ACGCET_Faculty.Views.MarkEntry"
             xmlns:smVm="clr-namespace:ACGCET_Faculty.ViewModels.StudentMaster"
             xmlns:smV="clr-namespace:ACGCET_Faculty.Views.StudentMaster"
             xmlns:newMeVm="clr-namespace:ACGCET_Faculty.ViewModels.MarksEntry"
             xmlns:newMeV="clr-namespace:ACGCET_Faculty.Views.MarksEntry"
             xmlns:resVm="clr-namespace:ACGCET_Faculty.ViewModels.Results"
             xmlns:resV="clr-namespace:ACGCET_Faculty.Views.Results"
             xmlns:eaVm="clr-namespace:ACGCET_Faculty.ViewModels.ExamApplication"
             xmlns:eaV="clr-namespace:ACGCET_Faculty.Views.ExamApplication"
             xmlns:rpVm="clr-namespace:ACGCET_Faculty.ViewModels.Reports"
             xmlns:rpV="clr-namespace:ACGCET_Faculty.Views.Reports"
             d:DataContext="{d:DesignInstance Type=vm:FacultyDashboardViewModel}"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1100">

    <UserControl.Resources>
        <!-- Sub-view DataTemplates -->
        <DataTemplate DataType="{x:Type meVm:InternalMarkEntryViewModel}">
            <meV:InternalMarkEntryView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type meVm:MyAuditLogViewModel}">
            <meV:MyAuditLogView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type smVm:StudentMasterViewModel}">
            <smV:StudentMasterView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type newMeVm:MarksEntryViewModel}">
            <newMeV:MarksEntryView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type resVm:ResultsViewModel}">
            <resV:ResultsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type eaVm:ExamApplicationViewModel}">
            <eaV:ExamApplicationView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type rpVm:MissingMarksViewModel}">
            <rpV:MissingMarksView/>
        </DataTemplate>

        <!-- Home page inline template -->
        <DataTemplate DataType="{x:Type vm:FacultyDashboardViewModel}">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          Background="{DynamicResource MaterialDesign.Brush.Background}">
                <StackPanel Margin="24 20">

                    <!-- Welcome banner -->
                    <Border  Padding="22 18" Margin="0 0 0 22">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#5E35B1" Offset="0"/>
                                <GradientStop Color="#5E35B1" Offset="0"/>
                                <GradientStop Color="#5E35B1" Offset="0"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect Color="#9C27B0" BlurRadius="20"
                                              ShadowDepth="0" Opacity="0.25"/>
                        </Border.Effect>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding WelcomeMessage}" FontSize="20"
                                           FontWeight="Bold" Foreground="White"/>
                                <TextBlock Text="{Binding CurrentDateTime}" FontSize="12"
                                           Foreground="#E1BEE7" Margin="0 4 0 0"/>
                            </StackPanel>
                            <md:PackIcon Grid.Column="1" Kind="AccountCircle"
                                         Width="56" Height="56" Foreground="#CE93DD"
                                         VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Status cards -->
                    <TextBlock Text="Module Status" FontSize="14" FontWeight="SemiBold"
                               Foreground="#5E35B1" Margin="0 0 0 10"/>
                    <UniformGrid Columns="3" Margin="0 0 0 22">
                        <!-- INT Marks card -->
                        <md:Card Margin="0 0 8 0" Background="White">
                            <Border Padding="18 16">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0 0 0 8">
                                        <md:PackIcon Kind="NoteEdit" Width="18" Height="18"
                                                     Foreground="#7B1FA2"
                                                     VerticalAlignment="Center"
                                                     Margin="0 0 8 0"/>
                                        <TextBlock Text="Internal Mark Entry"
                                                   FontSize="13" Foreground="#424242"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding InternalMarkStatus}"
                                               FontSize="14" FontWeight="Bold"
                                               Foreground="{Binding InternalMarkStatusColor}"/>
                                </StackPanel>
                            </Border>
                        </md:Card>

                        <!-- Exam Application card -->
                        <md:Card Margin="0 0 8 0" Background="White">
                            <Border Padding="18 16">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0 0 0 8">
                                        <md:PackIcon Kind="FileDocumentEdit" Width="18" Height="18"
                                                     Foreground="#1565C0"
                                                     VerticalAlignment="Center"
                                                     Margin="0 0 8 0"/>
                                        <TextBlock Text="Exam Application"
                                                   FontSize="13" Foreground="#424242"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding ExamAppStatus}"
                                               FontSize="14" FontWeight="Bold"
                                               Foreground="{Binding ExamAppStatusColor}"/>
                                </StackPanel>
                            </Border>
                        </md:Card>

                        <!-- Quick actions card -->
                        <md:Card Margin="0 0 0 0"
                                  Background="White">
                            <Border Padding="18 16">
                                <StackPanel>
                                    <TextBlock Text="Quick Actions" FontSize="12"
                                               Foreground="#9E9E9E" Margin="0 0 0 10"/>
                                    <Button Command="{Binding RefreshCommand}"
                                            Style="{StaticResource MaterialDesignOutlinedButton}"
                                            HorizontalAlignment="Left">
                                        <StackPanel Orientation="Horizontal">
                                            <md:PackIcon Kind="Refresh"
                                                         VerticalAlignment="Center"
                                                         Margin="0 0 6 0"/>
                                            <TextBlock Text="Refresh Status"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Border>
                        </md:Card>
                    </UniformGrid>

                    <!-- System Alerts -->
                    <Border  Padding="16" Margin="0 0 0 22"
                            BorderThickness="1"
                            Visibility="{Binding HasAlerts,
                                         Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Border.Background>
                            <SolidColorBrush Color="#FFEBEE"/>
                        </Border.Background>
                        <Border.BorderBrush>
                            <SolidColorBrush Color="#FFCDD2"/>
                        </Border.BorderBrush>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0 0 0 12">
                                <md:PackIcon Kind="AlertOctagon" Foreground="#C62828"
                                             Width="20" Height="20"
                                             VerticalAlignment="Center"
                                             Margin="0 0 8 0"/>
                                <TextBlock Text="System Alerts" FontSize="14"
                                           Foreground="#B71C1C" FontWeight="Bold"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <ItemsControl ItemsSource="{Binding SystemAlerts}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0 3" Padding="10 7" 
                                                Background="#FFF3F3">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="120"/>
                                                    <ColumnDefinition Width="70"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                    Text="{Binding AlertDateTime, StringFormat='{}{0:dd/MM HH:mm}'}"
                                                    Foreground="#EF5350" FontSize="11"/>
                                                <TextBlock Grid.Column="1"
                                                    Text="{Binding AlertSeverity}"
                                                    Foreground="#C62828" FontSize="11"
                                                    FontWeight="SemiBold"/>
                                                <TextBlock Grid.Column="2"
                                                    Text="{Binding AlertMessage}"
                                                    Foreground="#D32F2F" FontSize="11"
                                                    TextWrapping="Wrap"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- Recent Activity -->
                    <TextBlock Text="My Recent Activity" FontSize="14" FontWeight="SemiBold"
                               Foreground="#5E35B1" Margin="0 0 0 10"/>
                    <md:Card 
                             Background="White">
                        <DataGrid ItemsSource="{Binding MyRecentActivity}"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  CanUserAddRows="False" CanUserReorderColumns="False"
                                  HeadersVisibility="Column" MaxHeight="380"
                                  Style="{StaticResource MaterialDesignDataGrid}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Date / Time" Width="145"
                                    Binding="{Binding ActionDate, StringFormat='{}{0:dd/MM/yyyy HH:mm}'}"/>
                                <DataGridTextColumn Header="Action"      Width="90"
                                    Binding="{Binding ActionType}"/>
                                <DataGridTextColumn Header="Table"       Width="130"
                                    Binding="{Binding TableName}"/>
                                <DataGridTextColumn Header="Record ID"   Width="90"
                                    Binding="{Binding RecordId}"/>
                                <DataGridTextColumn Header="Description" Width="*"
                                    Binding="{Binding Description}"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </md:Card>

                </StackPanel>
            </ScrollViewer>
        </DataTemplate>
    </UserControl.Resources>

    <DockPanel Background="{DynamicResource MaterialDesign.Brush.Background}">

        <!-- ══ TOP BAR ═════════════════════════════════════════════════ -->
        <md:ColorZone Mode="PrimaryMid" DockPanel.Dock="Top" Padding="0">
            <Border Padding="18 12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Image Source="pack://application:,,,/Resources/Images/acgcet_logo.png"
                               Width="32" Height="32" VerticalAlignment="Center"
                               Margin="0 0 10 0"/>
                        <TextBlock Text="ACGCET Faculty — Mark Entry System"
                                   VerticalAlignment="Center" FontSize="16"
                                   FontWeight="SemiBold" Foreground="White"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <!-- Alert pill -->
                        <Border  Padding="10 4" Margin="0 0 16 0" Background="#33FFFFFF"
                                Visibility="{Binding HasAlerts,
                                             Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="Bell" Width="13" Height="13"
                                             Foreground="#fff" VerticalAlignment="Center"
                                             Margin="0 0 4 0"/>
                                <TextBlock Text="Alerts" Foreground="#fff" FontSize="11"/>
                            </StackPanel>
                        </Border>
                        <!-- Date -->
                        <TextBlock Text="{Binding CurrentDateTime}" FontSize="11"
                                   Foreground="#E1BEE7" VerticalAlignment="Center"
                                   Margin="0 0 16 0"/>
                        <!-- Status chips -->
                        <Border Padding="10 4" Background="#33FFFFFF"
                                Margin="0 0 6 0">
                            <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="White">
                                <Run Text="INT "/><Run Text="{Binding InternalMarkStatus}"/>
                            </TextBlock>
                        </Border>
                        <Border  Padding="10 4" Background="#33FFFFFF">
                            <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="White">
                                <Run Text="APP "/><Run Text="{Binding ExamAppStatus}"/>
                            </TextBlock>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>
        </md:ColorZone>

        <!-- ══ BODY ════════════════════════════════════════════════════ -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── SIDEBAR ─────────────────────────────────────────── -->
            <Border Grid.Column="0" Background="White"
                    BorderBrush="#E0E0E0" BorderThickness="0 0 1 0">
                <DockPanel>
                    <!-- User avatar -->
                    <StackPanel DockPanel.Dock="Top"
                                HorizontalAlignment="Center" Margin="0 24 0 20">
                        <Border Width="60" Height="60" CornerRadius="30"
                                HorizontalAlignment="Center" Margin="0 0 0 10">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#5E35B1" Offset="0"/>
                                    <GradientStop Color="#5E35B1" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <md:PackIcon Kind="Account" Width="36" Height="36"
                                         Foreground="White"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="{Binding WelcomeMessage}" FontSize="12"
                                   Foreground="#424242" HorizontalAlignment="Center"
                                   TextWrapping="Wrap" TextAlignment="Center"
                                   Margin="12 0" FontWeight="SemiBold"/>
                        <TextBlock Text="Faculty" FontSize="10" Foreground="#7B1FA2"
                                   HorizontalAlignment="Center" Margin="0 2 0 0"/>
                    </StackPanel>

                    <!-- Module status pills -->
                    <StackPanel DockPanel.Dock="Top" Margin="12 0 12 14">
                        <Border  Padding="10 8" BorderThickness="1" Margin="0 0 0 6">
                            <Border.Background>
                                <SolidColorBrush Color="{Binding InternalMarkStatusColor}" Opacity="0.08"/>
                            </Border.Background>
                            <Border.BorderBrush>
                                <SolidColorBrush Color="{Binding InternalMarkStatusColor}" Opacity="0.3"/>
                            </Border.BorderBrush>
                            <StackPanel>
                                <TextBlock Text="INT MARKS" FontSize="9"
                                           Foreground="#9E9E9E" FontWeight="Bold" Margin="0 0 0 2"/>
                                <TextBlock Text="{Binding InternalMarkStatus}"
                                           FontSize="11" FontWeight="SemiBold"
                                           Foreground="{Binding InternalMarkStatusColor}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                        <Border Padding="10 8" BorderThickness="1">
                            <Border.Background>
                                <SolidColorBrush Color="{Binding ExamAppStatusColor}" Opacity="0.08"/>
                            </Border.Background>
                            <Border.BorderBrush>
                                <SolidColorBrush Color="{Binding ExamAppStatusColor}" Opacity="0.3"/>
                            </Border.BorderBrush>
                            <StackPanel>
                                <TextBlock Text="EXAM APPLICATION" FontSize="9"
                                           Foreground="#9E9E9E" FontWeight="Bold" Margin="0 0 0 2"/>
                                <TextBlock Text="{Binding ExamAppStatus}"
                                           FontSize="11" FontWeight="SemiBold"
                                           Foreground="{Binding ExamAppStatusColor}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <Separator DockPanel.Dock="Top" Margin="12 0 12 4"/>

                    <!-- Nav menu -->
                    <StackPanel DockPanel.Dock="Top">
                        <StackPanel.Resources>
                            <Style TargetType="Button"
                                   BasedOn="{StaticResource MaterialDesignFlatButton}">
                                <Setter Property="HorizontalAlignment"        Value="Stretch"/>
                                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                <Setter Property="Height"   Value="46"/>
                                <Setter Property="Margin"   Value="4 1"/>
                                <Setter Property="Padding"  Value="16 0"/>
                                <Setter Property="Foreground" Value="#424242"/>
                            </Style>
                        </StackPanel.Resources>

                        <Button Command="{Binding NavigateToCommand}"
                                CommandParameter="Home">
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="ViewDashboard" VerticalAlignment="Center"
                                             Margin="0 0 10 0"/>
                                <TextBlock Text="Dashboard" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding NavigateToCommand}"
                                CommandParameter="InternalMarkEntry"
                                IsEnabled="{Binding IsInternalMarkOpen}"
                                Foreground="#6A1B9A">
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="NoteEdit" VerticalAlignment="Center"
                                             Margin="0 0 10 0"/>
                                <TextBlock Text="Internal Marks" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding NavigateToCommand}"
                                CommandParameter="MyAuditLog">
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="History" VerticalAlignment="Center"
                                             Margin="0 0 10 0"/>
                                <TextBlock Text="My Audit Log" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        
                        <Separator Margin="12 8"/>
                        
                        <Button Command="{Binding NavigateToCommand}"
                                CommandParameter="StudentMaster">
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="AccountMultiple" VerticalAlignment="Center"
                                             Margin="0 0 10 0"/>
                                <TextBlock Text="Student Master" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        
                        <Button Command="{Binding NavigateToCommand}"
                                CommandParameter="MarksEntry">
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="TableEdit" VerticalAlignment="Center"
                                             Margin="0 0 10 0"/>
                                <TextBlock Text="Marks Entry Module" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        
                        <Button Command="{Binding NavigateToCommand}"
                                CommandParameter="Results">
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="FileChart" VerticalAlignment="Center"
                                             Margin="0 0 10 0"/>
                                <TextBlock Text="Results (Read-Only)" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Separator Margin="12 8"/>

                        <Button Command="{Binding NavigateToCommand}"
                                CommandParameter="ExamApplication"
                                IsEnabled="{Binding IsExamAppOpen}"
                                Foreground="#1565C0">
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="FileDocumentEdit" VerticalAlignment="Center"
                                             Margin="0 0 10 0"/>
                                <TextBlock Text="Exam Application" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding NavigateToCommand}"
                                CommandParameter="MissingMarks"
                                Foreground="#E65100">
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="ClipboardAlert" VerticalAlignment="Center"
                                             Margin="0 0 10 0"/>
                                <TextBlock Text="Missing Marks" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- Logout at bottom -->
                    <Button DockPanel.Dock="Bottom"
                            Command="{Binding LogoutCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Foreground="#C62828" BorderBrush="#FFCDD2"
                            HorizontalAlignment="Stretch"
                            Margin="12 0 12 20" Height="40">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="Logout" VerticalAlignment="Center"
                                         Margin="0 0 6 0"/>
                            <TextBlock Text="Logout" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Rectangle/>
                </DockPanel>
            </Border>

            <!-- ── CONTENT AREA ────────────────────────────────────── -->
            <ContentControl Grid.Column="1" Content="{Binding CurrentView}"/>
        </Grid>
    </DockPanel>
</UserControl>
