<UserControl x:Class="ACGCET_Faculty.Views.MarksEntry.MarksEntryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:ACGCET_Faculty.ViewModels.MarksEntry"
             d:DataContext="{d:DesignInstance Type=vm:MarksEntryViewModel}"
             mc:Ignorable="d"
             d:DesignHeight="700"
        d:DesignWidth="1000"
             Background="{DynamicResource MaterialDesign.Brush.Background}">

    <Grid Margin="20 16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel Grid.Row="0"
                Orientation="Horizontal"
                Margin="0 0 0 14">
            <md:PackIcon Kind="NotebookEditOutline"
                    Width="26"
                    Height="26"
                         Foreground="#6A1B9A"
                    VerticalAlignment="Center"
                    Margin="0 0 10 0"/>
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Marks Review"
                        FontSize="20"
                        FontWeight="Bold"
                           Foreground="#4A148C"/>
                <TextBlock Text="Read-only summary of entered internal marks"
                           FontSize="11"
                        Foreground="#9E9E9E"/>
            </StackPanel>
        </StackPanel>

        <!-- Lock Banner -->
        <Border Grid.Row="1"
                Padding="14 10"
                Margin="0 0 0 12"
                Background="#FFF3E0"
                BorderBrush="#FFCC80"
                BorderThickness="1"
                Visibility="{Binding IsModuleLocked, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel Orientation="Horizontal">
                <md:PackIcon Kind="Lock"
                        Width="18"
                        Height="18"
                        Foreground="#E65100"
                             VerticalAlignment="Center"
                        Margin="0 0 10 0"/>
                <TextBlock Text="{Binding LockMessage}"
                        FontSize="12"
                        FontWeight="SemiBold"
                           Foreground="#E65100"
                        VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Filter Card -->
        <md:Card Grid.Row="2"
                Margin="0 0 0 12"
                 Padding="16 14"
                Background="White">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ComboBox Grid.Column="0"
                        Margin="0 0 10 0"
                          ItemsSource="{Binding Courses}"
                          SelectedItem="{Binding SelectedCourse}"
                          md:HintAssist.Hint="Course"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          Background="White"
                          DisplayMemberPath="CourseName"/>
                <ComboBox Grid.Column="1"
                        Margin="0 0 10 0"
                          ItemsSource="{Binding Batches}"
                          SelectedItem="{Binding SelectedBatch}"
                          md:HintAssist.Hint="Batch"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          Background="White"
                          DisplayMemberPath="BatchName"/>
                <ComboBox Grid.Column="2"
                        Margin="0 0 10 0"
                          ItemsSource="{Binding Sections}"
                          SelectedItem="{Binding SelectedSection}"
                          md:HintAssist.Hint="Section (optional)"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          Background="White"
                          DisplayMemberPath="SectionName"/>
                <ComboBox Grid.Column="3"
                        Margin="0 0 10 0"
                          ItemsSource="{Binding Semesters}"
                          SelectedItem="{Binding SelectedSemester}"
                          md:HintAssist.Hint="Semester (optional)"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          Background="White"/>
                <Button Grid.Column="4"
                        Command="{Binding LoadMarksCommand}"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Background="#FF673AB7"
                        Foreground="White"
                        BorderBrush="#FF673AB7"
                        Height="40">
                    <StackPanel Orientation="Horizontal">
                        <md:PackIcon Kind="Magnify"
                                VerticalAlignment="Center"
                                Margin="0 0 6 0"/>
                        <TextBlock Text="Load Marks"
                                VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </md:Card>

        <!-- Status Message -->
        <Border Grid.Row="3"
                Padding="10 7"
                Margin="0 0 0 10"
                BorderThickness="1"
                Visibility="{Binding StatusMessage, Converter={StaticResource StringToVisibilityConverter}}">
            <Border.Background>
                <SolidColorBrush Color="{Binding StatusColor}"
                        Opacity="0.08"/>
            </Border.Background>
            <Border.BorderBrush>
                <SolidColorBrush Color="{Binding StatusColor}"
                        Opacity="0.3"/>
            </Border.BorderBrush>
            <StackPanel Orientation="Horizontal">
                <md:PackIcon Kind="InformationOutline"
                        Width="16"
                        Height="16"
                             Foreground="{Binding StatusColor}"
                             VerticalAlignment="Center"
                        Margin="0 0 8 0"/>
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{Binding StatusColor}"
                           FontSize="12"
                        FontWeight="SemiBold"
                        VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Marks Grid -->
        <md:Card Grid.Row="4"
                 ClipToBounds="True"
                Background="White">
            <Grid>
                <!-- Loading -->
                <Border Panel.ZIndex="10"
                        Background="#F5F5F5"
                        Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                        <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                                     IsIndeterminate="True"
                                Value="0"
                                Width="44"
                                Height="44"/>
                        <TextBlock Text="Loading marks..."
                                Foreground="#7B1FA2"
                                   FontSize="13"
                                HorizontalAlignment="Center"
                                Margin="0 12 0 0"/>
                    </StackPanel>
                </Border>

                <!-- Empty state -->
                <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Margin="0 40">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility"
                                    Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasMarks}"
                                        Value="False">
                                    <Setter Property="Visibility"
                                            Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <md:PackIcon Kind="NotebookOutline"
                            Width="64"
                            Height="64"
                                 Foreground="#BDBDBD"
                            HorizontalAlignment="Center"/>
                    <TextBlock Text="Select a Course and click Load Marks"
                               Foreground="#9E9E9E"
                            FontSize="14"
                               HorizontalAlignment="Center"
                            Margin="0 12 0 4"/>
                    <TextBlock Text="Use Internal Mark Entry to add or edit marks"
                               Foreground="#BDBDBD"
                            FontSize="12"
                            HorizontalAlignment="Center"/>
                </StackPanel>

                <DataGrid ItemsSource="{Binding MarksList}"
                          AutoGenerateColumns="False"
                        IsReadOnly="True"
                          CanUserAddRows="False"
                        CanUserReorderColumns="False"
                          HeadersVisibility="Column"
                          Style="{StaticResource MaterialDesignDataGrid}"
                          Visibility="{Binding HasMarks, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Roll No"
                                Width="80"
                                IsReadOnly="True"
                                            Binding="{Binding Student.RollNumber}"/>
                        <DataGridTextColumn Header="Reg No"
                                Width="115"
                                IsReadOnly="True"
                                            Binding="{Binding Student.RegistrationNumber}"/>
                        <DataGridTextColumn Header="Student Name"
                                Width="*"
                                IsReadOnly="True"
                                            Binding="{Binding Student.FullName}"/>
                        <DataGridTextColumn Header="Paper"
                                Width="80"
                                IsReadOnly="True"
                                            Binding="{Binding Paper.PaperCode}"/>
                        <DataGridTextColumn Header="Paper Name"
                                Width="180"
                                IsReadOnly="True"
                                            Binding="{Binding Paper.PaperName}"/>
                        <DataGridTextColumn Header="Test"
                                Width="70"
                                IsReadOnly="True"
                                            Binding="{Binding TestType.TestName}"/>
                        <DataGridTextColumn Header="Sem"
                                Width="50"
                                IsReadOnly="True"
                                            Binding="{Binding Semester}"/>
                        <DataGridTextColumn Header="Mark"
                                Width="60"
                                IsReadOnly="True"
                                            Binding="{Binding Mark}"/>
                        <DataGridTextColumn Header="Max"
                                Width="55"
                                IsReadOnly="True"
                                            Binding="{Binding MaxMark}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </md:Card>
    </Grid>
</UserControl>
