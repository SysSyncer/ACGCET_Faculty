<UserControl x:Class="ACGCET_Faculty.Views.Results.ResultsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:ACGCET_Faculty.ViewModels.Results"
             d:DataContext="{d:DesignInstance Type=vm:ResultsViewModel}"
             mc:Ignorable="d"
             d:DesignHeight="700"
        d:DesignWidth="1000"
             Background="{DynamicResource MaterialDesign.Brush.Background}">

    <Grid Margin="20 16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel Grid.Row="0"
                Orientation="Horizontal"
                Margin="0 0 0 14">
            <md:PackIcon Kind="FileChart"
                    Width="26"
                    Height="26"
                         Foreground="#6A1B9A"
                    VerticalAlignment="Center"
                    Margin="0 0 10 0"/>
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Published Results"
                        FontSize="20"
                        FontWeight="Bold"
                           Foreground="#4A148C"/>
                <TextBlock Text="Only COE-authorized results are visible here"
                           FontSize="11"
                        Foreground="#9E9E9E"/>
            </StackPanel>
            <Button Content="REQUEST CORRECTION"
                    Margin="20 0 0 0"
                    Command="{Binding RequestCorrectionCommand}"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Foreground="#C62828"
                    BorderBrush="#FFCDD2"
                    VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Filter Card -->
        <md:Card Grid.Row="1"
                Margin="0 0 0 12"
                 Padding="16 14"
                Background="White">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ComboBox Grid.Column="0"
                        Margin="0 0 10 0"
                          ItemsSource="{Binding Examinations}"
                          SelectedItem="{Binding SelectedExamination}"
                          md:HintAssist.Hint="Examination (optional — all if blank)"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          Background="White">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock>
                                <Run Text="{Binding ExamCode, Mode=OneWay}"/>
                                <Run Text=" ("/>
                                <Run Text="{Binding ExamMonth, Mode=OneWay}"/>
                                <Run Text=" "/>
                                <Run Text="{Binding ExamYear, Mode=OneWay}"/>
                                <Run Text=")"/>
                            </TextBlock>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <ComboBox Grid.Column="1"
                        Margin="0 0 10 0"
                          ItemsSource="{Binding Courses}"
                          SelectedItem="{Binding SelectedCourse}"
                          md:HintAssist.Hint="Course (optional — all if blank)"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          Background="White"
                          DisplayMemberPath="CourseName"/>
                <Button Grid.Column="2"
                        Command="{Binding LoadResultsCommand}"
                        Style="{StaticResource MaterialDesignFlatAccentBgButton}"
                        Background="#FF673AB7"
                        Foreground="White"
                        BorderBrush="#FF673AB7"
                        Height="40">
                    <StackPanel Orientation="Horizontal">
                        <md:PackIcon Kind="Magnify"
                                VerticalAlignment="Center"
                                Margin="0 0 6 0"/>
                        <TextBlock Text="Load Results"
                                VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </md:Card>

        <!-- Status Message -->
        <Border Grid.Row="2"
                Padding="10 7"
                Margin="0 0 0 10"
                BorderThickness="1"
                Visibility="{Binding StatusMessage, Converter={StaticResource StringToVisibilityConverter}}">
            <Border.Background>
                <SolidColorBrush Color="{Binding StatusColor}"
                        Opacity="0.08"/>
            </Border.Background>
            <Border.BorderBrush>
                <SolidColorBrush Color="{Binding StatusColor}"
                        Opacity="0.3"/>
            </Border.BorderBrush>
            <StackPanel Orientation="Horizontal">
                <md:PackIcon Kind="InformationOutline"
                        Width="16"
                        Height="16"
                             Foreground="{Binding StatusColor}"
                             VerticalAlignment="Center"
                        Margin="0 0 8 0"/>
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{Binding StatusColor}"
                           FontSize="12"
                        FontWeight="SemiBold"
                        VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Correction Request Panel -->
        <md:Card Grid.Row="3"
                Margin="0 0 0 12"
                Padding="16 14"
                Background="#FFF3E0"
                 Visibility="{Binding IsCorrectionPanelVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel>
                <TextBlock Text="Submit Data Correction Request"
                        FontWeight="Bold"
                        FontSize="14"
                           Foreground="#E65100"
                        Margin="0 0 0 10"/>
                <TextBlock Text="{Binding SelectedResult.Student.RegistrationNumber, StringFormat='Student: {0}'}"
                           FontSize="12"
                        Foreground="#666"
                        Margin="0 0 0 4"/>
                <TextBlock Text="{Binding SelectedResult.Paper.PaperCode, StringFormat='Paper: {0}'}"
                           FontSize="12"
                        Foreground="#666"
                        Margin="0 0 0 8"/>
                <TextBox Text="{Binding CorrectionReason, UpdateSourceTrigger=PropertyChanged}"
                         md:HintAssist.Hint="Reason for correction (required)"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Background="White"
                        MinLines="2"
                        TextWrapping="Wrap"
                         Margin="0 0 0 8"/>
                <TextBox Text="{Binding ProposedValue, UpdateSourceTrigger=PropertyChanged}"
                         md:HintAssist.Hint="Proposed correct value (optional)"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Background="White"
                        Margin="0 0 0 10"/>
                <StackPanel Orientation="Horizontal">
                    <Button Content="SUBMIT REQUEST"
                            Command="{Binding SubmitCorrectionCommand}"
                            Style="{StaticResource MaterialDesignFlatAccentBgButton}"
                            Background="#E65100"
                            Foreground="White"
                            BorderBrush="#E65100"
                            Margin="0 0 10 0"/>
                    <Button Content="CANCEL"
                            Command="{Binding CancelCorrectionCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Foreground="#666"
                            BorderBrush="#CCC"/>
                </StackPanel>
            </StackPanel>
        </md:Card>

        <!-- Results Grid -->
        <md:Card Grid.Row="4"
                 ClipToBounds="True"
                Background="White">
            <Grid>
                <!-- Loading -->
                <Border Panel.ZIndex="10"
                        Background="#F5F5F5"
                        Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                        <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                                     IsIndeterminate="True"
                                Value="0"
                                Width="44"
                                Height="44"/>
                        <TextBlock Text="Loading results..."
                                Foreground="#7B1FA2"
                                   FontSize="13"
                                HorizontalAlignment="Center"
                                Margin="0 12 0 0"/>
                    </StackPanel>
                </Border>

                <!-- Empty state -->
                <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Margin="0 40">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility"
                                    Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasResults}"
                                        Value="False">
                                    <Setter Property="Visibility"
                                            Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <md:PackIcon Kind="FileChartOutline"
                            Width="64"
                            Height="64"
                                 Foreground="#BDBDBD"
                            HorizontalAlignment="Center"/>
                    <TextBlock Text="Select filters and click Load Results"
                               Foreground="#9E9E9E"
                            FontSize="14"
                               HorizontalAlignment="Center"
                            Margin="0 12 0 4"/>
                    <TextBlock Text="Only COE-published results will appear"
                               Foreground="#BDBDBD"
                            FontSize="12"
                            HorizontalAlignment="Center"/>
                </StackPanel>

                <DataGrid ItemsSource="{Binding ResultsList}"
                          SelectedItem="{Binding SelectedResult}"
                          AutoGenerateColumns="False"
                        IsReadOnly="True"
                          CanUserAddRows="False"
                        CanUserReorderColumns="False"
                          HeadersVisibility="Column"
                          Style="{StaticResource MaterialDesignDataGrid}"
                          Visibility="{Binding HasResults, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Reg No"
                                Width="115"
                                IsReadOnly="True"
                                            Binding="{Binding Student.RegistrationNumber}"/>
                        <DataGridTextColumn Header="Student Name"
                                Width="*"
                                IsReadOnly="True"
                                            Binding="{Binding Student.FullName}"/>
                        <DataGridTextColumn Header="Paper"
                                Width="80"
                                IsReadOnly="True"
                                            Binding="{Binding Paper.PaperCode}"/>
                        <DataGridTextColumn Header="Paper Name"
                                Width="200"
                                IsReadOnly="True"
                                            Binding="{Binding Paper.PaperName}"/>
                        <DataGridTextColumn Header="Internal"
                                Width="70"
                                IsReadOnly="True"
                                            Binding="{Binding InternalTotal}"/>
                        <DataGridTextColumn Header="External"
                                Width="70"
                                IsReadOnly="True"
                                            Binding="{Binding ExternalTotal}"/>
                        <DataGridTextColumn Header="Grand Total"
                                Width="90"
                                IsReadOnly="True"
                                            Binding="{Binding GrandTotal}"/>
                        <DataGridTextColumn Header="Grade"
                                Width="60"
                                IsReadOnly="True"
                                            Binding="{Binding Grade}"/>
                        <DataGridTextColumn Header="Result"
                                Width="90"
                                IsReadOnly="True"
                                            Binding="{Binding ResultStatus.StatusName}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </md:Card>
    </Grid>
</UserControl>
