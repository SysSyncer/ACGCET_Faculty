<UserControl x:Class="ACGCET_Faculty.Views.ExamApplication.ExamApplicationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:ACGCET_Faculty.ViewModels.ExamApplication"
             d:DataContext="{d:DesignInstance Type=vm:ExamApplicationViewModel}"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1000"
             Background="{DynamicResource MaterialDesign.Brush.Background}">

    <Grid Margin="20 16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0 0 0 14">
            <md:PackIcon Kind="FileDocumentEdit" Width="26" Height="26"
                         Foreground="#6A1B9A" VerticalAlignment="Center"
                         Margin="0 0 10 0"/>
            <TextBlock Text="Exam Application" FontSize="20"
                       FontWeight="Bold" Foreground="#4A148C"
                       VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Lock Warning -->
        <Border Grid.Row="1"  Padding="16 12"
                Margin="0 0 0 14" BorderThickness="1"
                Visibility="{Binding IsModuleLocked,
                             Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border.Background><SolidColorBrush Color="#FFEBEE"/></Border.Background>
            <Border.BorderBrush><SolidColorBrush Color="#FFCDD2"/></Border.BorderBrush>
            <StackPanel Orientation="Horizontal">
                <md:PackIcon Kind="Lock" Foreground="#C62828"
                             Width="22" Height="22" VerticalAlignment="Center"
                             Margin="0 0 12 0"/>
                <TextBlock Text="{Binding LockMessage}" Foreground="#B71C1C"
                           FontSize="13" FontWeight="SemiBold"
                           TextWrapping="Wrap" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Filter Card -->
        <md:Card Grid.Row="2" Margin="0 0 0 12" 
                 Padding="16 14"
                 Background="White">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Row 1: Course / Batch / Section -->
                <Grid Grid.Row="0" Margin="0 0 0 12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <ComboBox Grid.Column="0" Margin="0 0 10 0"
                              ItemsSource="{Binding Courses}"
                              SelectedItem="{Binding SelectedCourse}"
                              md:HintAssist.Hint="Course / Department"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                              DisplayMemberPath="CourseName"/>
                    <ComboBox Grid.Column="1" Margin="0 0 10 0"
                              ItemsSource="{Binding Batches}"
                              SelectedItem="{Binding SelectedBatch}"
                              md:HintAssist.Hint="Batch"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                              DisplayMemberPath="BatchName"/>
                    <ComboBox Grid.Column="2"
                              ItemsSource="{Binding Sections}"
                              SelectedItem="{Binding SelectedSection}"
                              md:HintAssist.Hint="Section"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                              DisplayMemberPath="SectionName"/>
                </Grid>

                <!-- Row 2: Semester / Examination / Load -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ComboBox Grid.Column="0" Margin="0 0 10 0"
                              ItemsSource="{Binding Semesters}"
                              SelectedItem="{Binding SelectedSemester}"
                              md:HintAssist.Hint="Sem"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}"/>
                    <ComboBox Grid.Column="1" Margin="0 0 10 0"
                              ItemsSource="{Binding Examinations}"
                              SelectedItem="{Binding SelectedExamination}"
                              md:HintAssist.Hint="Examination"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock>
                                    <Run Text="{Binding ExamCode, Mode=OneWay}"/>
                                    <Run Text=" ("/>
                                    <Run Text="{Binding ExamMonth, Mode=OneWay}"/>
                                    <Run Text=" "/>
                                    <Run Text="{Binding ExamYear, Mode=OneWay}"/>
                                    <Run Text=")"/>
                                </TextBlock>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <Button Grid.Column="2"
                            Command="{Binding LoadStudentsCommand}"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                             Height="40">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="AccountSearch" VerticalAlignment="Center"
                                         Margin="0 0 6 0"/>
                            <TextBlock Text="Load Students" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Grid>
        </md:Card>

        <!-- Stats Bar -->
        <Border Grid.Row="3"  Padding="14 10" Margin="0 0 0 10"
                Background="White" BorderThickness="1" BorderBrush="#E8EAF6"
                Visibility="{Binding HasStudents,
                             Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel Orientation="Horizontal">
                <md:PackIcon Kind="AccountMultiple" Foreground="#5C6BC0"
                             VerticalAlignment="Center" Margin="0 0 8 0"/>
                <TextBlock Foreground="#424242" FontSize="12" VerticalAlignment="Center">
                    <Run Text="Total: " FontWeight="SemiBold"/>
                    <Run Text="{Binding TotalStudents}" Foreground="#5C6BC0" FontWeight="Bold"/>
                    <Run Text="   Applied: " FontWeight="SemiBold"/>
                    <Run Text="{Binding AppliedCount}" Foreground="#2E7D32" FontWeight="Bold"/>
                    <Run Text="   Not Applied: " FontWeight="SemiBold"/>
                    <Run Text="{Binding NotAppliedCount}" Foreground="#C62828" FontWeight="Bold"/>
                </TextBlock>

                <!-- Bulk buttons -->
                <Button Content="Select All" Margin="20 0 8 0" Height="28" Padding="12 0"
                        Command="{Binding SelectAllCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                         FontSize="11"/>
                <Button Content="Clear New" Height="28" Padding="12 0"
                        Command="{Binding ClearNewCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                         FontSize="11"
                        Foreground="#C62828" BorderBrush="#FFCDD2"/>
            </StackPanel>
        </Border>

        <!-- Status Message -->
        <Border Grid.Row="4"  Padding="10 7" Margin="0 0 0 10"
                BorderThickness="1"
                Visibility="{Binding StatusMessage,
                             Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border.Background>
                <SolidColorBrush Color="{Binding StatusColor}" Opacity="0.08"/>
            </Border.Background>
            <Border.BorderBrush>
                <SolidColorBrush Color="{Binding StatusColor}" Opacity="0.3"/>
            </Border.BorderBrush>
            <StackPanel Orientation="Horizontal">
                <md:PackIcon Kind="InformationOutline" Width="16" Height="16"
                             Foreground="{Binding StatusColor}"
                             VerticalAlignment="Center" Margin="0 0 8 0"/>
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{Binding StatusColor}"
                           FontSize="12" FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Student DataGrid -->
        <md:Card Grid.Row="5" 
                 ClipToBounds="True"
                 Background="White">
            <Grid>
                <!-- Loading overlay -->
                <Border Panel.ZIndex="10"  Background="#F5F5F5"
                        Visibility="{Binding IsLoading,
                                     Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                                     IsIndeterminate="True" Value="0"
                                     Width="44" Height="44"/>
                        <TextBlock Text="Loading..." Foreground="#7B1FA2"
                                   FontSize="13" HorizontalAlignment="Center"
                                   Margin="0 12 0 0"/>
                    </StackPanel>
                </Border>

                <!-- Empty state -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                            Margin="0 40">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasStudents}" Value="False">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <md:PackIcon Kind="FileDocumentOutline" Width="64" Height="64"
                                 Foreground="#BDBDBD" HorizontalAlignment="Center"/>
                    <TextBlock Text="Select filters and click Load Students"
                               Foreground="#9E9E9E" FontSize="14"
                               HorizontalAlignment="Center" Margin="0 12 0 4"/>
                    <TextBlock Text="Tick students to register their exam applications"
                               Foreground="#BDBDBD" FontSize="12"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Students DataGrid -->
                <DataGrid ItemsSource="{Binding Students}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False" CanUserDeleteRows="False"
                          CanUserReorderColumns="False"
                          HeadersVisibility="Column" SelectionMode="Single"
                          Style="{StaticResource MaterialDesignDataGrid}"
                          Visibility="{Binding HasStudents,
                                       Converter={StaticResource BooleanToVisibilityConverter}}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="#"            Width="50"  IsReadOnly="True"
                            Binding="{Binding RollNumber}"/>
                        <DataGridTextColumn Header="Reg No"       Width="115" IsReadOnly="True"
                            Binding="{Binding RegistrationNumber}"/>
                        <DataGridTextColumn Header="Student Name"  Width="*"  IsReadOnly="True"
                            Binding="{Binding FullName}"/>
                        <DataGridTextColumn Header="Status"        Width="110" IsReadOnly="True"
                            Binding="{Binding ApprovalStatus}"/>
                        <DataGridTextColumn Header="Fees"          Width="80"  IsReadOnly="True"
                            Binding="{Binding TotalFees, StringFormat='{}{0:N2}'}"/>

                        <!-- Apply checkbox — disabled for already-registered students -->
                        <DataGridTemplateColumn Header="Apply" Width="72">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsApplied, UpdateSourceTrigger=PropertyChanged}"
                                              HorizontalAlignment="Center"
                                              IsEnabled="{Binding IsNew}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </md:Card>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="6" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0 14 0 0">
            <Button Command="{Binding SaveApplicationsCommand}"
                    IsEnabled="{Binding CanSave}"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Padding="24 10">
                <StackPanel Orientation="Horizontal">
                    <md:PackIcon Kind="ContentSave" VerticalAlignment="Center"
                                 Margin="0 0 8 0"/>
                    <TextBlock Text="Save Applications" VerticalAlignment="Center"
                               FontWeight="SemiBold"/>
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
